{
  "name": "casaticket",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm -r --parallel --filter @casaticket/mobile --filter @casaticket/admin dev",
    "dev:mobile": "corepack pnpm --filter @casaticket/mobile dev",
    "dev:admin": "corepack pnpm --filter @casaticket/admin dev",
    "dev:turbo": "corepack pnpm exec turbo run dev --parallel",
    "lint": "corepack pnpm -r --if-present lint && eslint playwright.config.ts supabase --ext .ts",
    "typecheck": "corepack pnpm -r --if-present typecheck && tsc --noEmit -p tsconfig.json",
    "test": "corepack pnpm -r --if-present test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:seed:users": "tsx supabase/scripts/seed-demo-users.ts",
    "db:test:rls": "tsx supabase/tests/rls-smoke.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.0",
    "@supabase/supabase-js": "^2.53.0",
    "@types/node": "^24.0.12",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "supabase": "latest",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^2.1.9"
  }
}
